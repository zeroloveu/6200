{
  "name": "secure-voting-course-project",
  "version": "1.0.0",
  "description": "A hybrid FastAPI + on-chain voting application",
  "main": "index.js",
  "scripts": {
    "clean": "hardhat clean",
    "compile": "hardhat compile",
